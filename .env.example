APP_NAME=AI Media Watch
APP_ENV=production
LOG_LEVEL=INFO

POSTGRES_DB=mediawatch
POSTGRES_USER=mediawatch
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg://mediawatch:change-me@postgres:5432/mediawatch

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin-change-me
S3_BUCKET=mediawatch-assets
S3_REGION=us-east-1
S3_SECURE=false

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-change-me

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_USER_AGENTS=
PROXY_URLS=
PROXY_ROTATION_STRATEGY=round_robin

COLLECT_KEYWORDS_INTERVAL_MINUTES=30
MONITOR_ACCOUNTS_INTERVAL_MINUTES=30

TIKTOK_RESEARCH_API_TOKEN=
INSTAGRAM_GRAPH_API_TOKEN=

